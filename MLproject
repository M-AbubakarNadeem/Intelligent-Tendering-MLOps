name: intelligent-tendering-mlops

conda_env: conda.yml

entry_points:
  train_single:
    parameters:
      epochs: {type: int, default: 10}
      batch_size: {type: int, default: 32}
      learning_rate: {type: float, default: 1e-05}
      dropout: {type: float, default: 0.3}
      model_name: {type: str, default: "bert-base-uncased"}
      max_len: {type: int, default: 128}
    command: "python src/training/train.py --model_type sinsent --epochs {epochs} --batch_size {batch_size} --learning_rate {learning_rate} --dropout {dropout} --model_name {model_name} --max_len {max_len}"

  train_sequential:
    parameters:
      epochs: {type: int, default: 10}
      batch_size: {type: int, default: 8}
      learning_rate: {type: float, default: 5e-06}
      dropout: {type: float, default: 0.1}
      model_name: {type: str, default: "bert-base-uncased"}
      max_len: {type: int, default: 128}
    command: "python src/training/train.py --model_type seqsent --epochs {epochs} --batch_size {batch_size} --learning_rate {learning_rate} --dropout {dropout} --model_name {model_name} --max_len {max_len}"

  evaluate:
    parameters:
      model_type: {type: str, default: "seqsent"}
      run_id: {type: str, default: "latest"}
    command: "python src/training/evaluate.py --model_type {model_type} --run_id {run_id}"

  compare:
    command: "python src/training/compare_models.py"
